# 复制本文件为 .env 后填写真实密钥（切勿将 .env 提交到 Git）
# 注意：以下变量也可直接写入操作系统环境变量（Windows 系统属性 → 高级 → 环境变量）

# ── 必填：AI 分析密钥 ──────────────────────────────────────────────────────────
DASHSCOPE_API_KEY=           # 阿里云百炼平台（录音转写 ASR 必填）
DEEPSEEK_API_KEY=            # DeepSeek（LLM 分析必填）

# ── 可选：共享网盘 / 多人协作路径覆盖 ─────────────────────────────────────────
# 设置后，记忆库和 ASR 缓存将写入指定目录，而非本地项目文件夹。
# 适用场景：挂载 123 网盘 / 企业 NAS / SMB 共享盘，实现多同事共享数据。
#
# 示例（Windows 挂载盘盘符）：
#   MEMORY_ROOT=Z:\AI路演教练\executive_memory
#   CACHE_ROOT=Z:\AI路演教练\asr_cache
#
# 示例（NAS 或 WSL 路径）：
#   MEMORY_ROOT=/mnt/nas/ai_pitch_coach/memory
#   CACHE_ROOT=/mnt/nas/ai_pitch_coach/cache
#
# 留空则使用本地默认路径：<项目根目录>/.executive_memory 和 .asr_cache
MEMORY_ROOT=
CACHE_ROOT=
